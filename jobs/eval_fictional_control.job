#!/usr/bin/env bash
#SBATCH --job-name=kinshipqa_fictional
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=150G
#SBATCH --time=48:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=%x-%j.log
#SBATCH --error=%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gres=gpu:1

# KinshipQA Fictional-Rule Control
# ---------------------------------
# For each non-Western system we generate a relabelled dataset where
# the system name and the cultural kin-term labels are replaced with
# fictional ones (rule structure preserved).  We then evaluate the
# three open-source models on the relabelled Cat.4 questions under
# zero_shot_direct.  Comparing accuracy on real vs. fictional labels
# isolates "applying any unfamiliar reclassification rule" from
# "applying culturally specific rules", addressing the W1 critique.

cd ~/scratch/Family-Tree-reasoning/familytree_v6/

module load Miniconda3
source activate MHQA

# Build the fictional datasets (cheap, ~1 second)
python make_fictional_cat4.py \
    --input-dir ./datasets/ \
    --output-dir ./datasets_fictional/

# Start Ollama
OLLAMA_MODELS=~/scratch/ollama_model ~/scratch/bin/ollama serve &
OLLAMA_PID=$!
sleep 10

echo "========================================"
echo "KinshipQA Fictional-Rule Control"
echo "Started: $(date)"
echo "========================================"

MODELS=("gemma3:27b" "deepseek-r1:32b" "qwen3:32b")
MODEL_NAMES=("gemma3_27b" "deepseek_r1_32b" "qwen3_32b")

for i in "${!MODELS[@]}"; do
    MODEL="${MODELS[$i]}"
    MODEL_NAME="${MODEL_NAMES[$i]}"
    OUTPUT_DIR="./results_fictional_${MODEL_NAME}_zero_shot_direct"

    echo ""
    echo "========================================"
    echo "Model: ${MODEL} | Fictional Cat.4"
    echo "Output: ${OUTPUT_DIR}"
    echo "Time: $(date)"
    echo "========================================"

    if [ -f "${OUTPUT_DIR}/combined_results.json" ]; then
        echo "Results already exist, skipping..."
        continue
    fi

    # We only care about Cat.4; --categories 4 keeps the rest fast.
    python llm_tester_v6.py \
        --all \
        --dataset-dir ./datasets_fictional/ \
        --provider ollama \
        --model "$MODEL" \
        --protocol zero_shot_direct \
        --categories 4 \
        --output-dir "$OUTPUT_DIR" \
        --verbose

    echo "Completed: ${MODEL} at $(date)"
done

kill $OLLAMA_PID 2>/dev/null

echo ""
echo "========================================"
echo "Building real-vs-fictional comparison"
echo "========================================"

python compare_fictional_to_real.py \
    --real-dir-template "./results_{model}_zero_shot_direct" \
    --fictional-dir-template "./results_fictional_{model}_zero_shot_direct" \
    --models gemma3_27b deepseek_r1_32b qwen3_32b \
    --output ./tables/fictional_control_comparison.json

echo ""
echo "========================================"
echo "All evaluations complete: $(date)"
echo "========================================"
