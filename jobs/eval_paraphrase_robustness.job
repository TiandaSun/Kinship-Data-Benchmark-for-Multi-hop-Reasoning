#!/usr/bin/env bash
#SBATCH --job-name=kinshipqa_paraphrase
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=200G
#SBATCH --time=02:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=%x-%j.log
#SBATCH --error=%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gres=gpu:1

# Paraphrase robustness probe — 50 Cat.4 questions (10 per Other-5 system)
# re-run on Gemma3-27B with rule-based paraphrased question text (context held
# fixed). Anchors against the existing zero_shot_direct headline results for
# the same 50 question IDs.

cd ~/scratch/Family-Tree-reasoning/familytree_v6/paraphrase_robustness/

module load Miniconda3
source activate MHQA

echo "========================================"
echo "Paraphrase robustness | Gemma3-27B | n=50"
echo "Started: $(date)"
echo "========================================"

OLLAMA_MODELS=~/scratch/ollama_model ~/scratch/bin/ollama serve &
OLLAMA_PID=$!
sleep 10

python run_paraphrase_inference.py

kill $OLLAMA_PID 2>/dev/null
echo ""
echo "Finished: $(date)"
