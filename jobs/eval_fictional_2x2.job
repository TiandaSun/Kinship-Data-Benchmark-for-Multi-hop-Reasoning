#!/usr/bin/env bash
#SBATCH --job-name=kinshipqa_fic2x2
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=150G
#SBATCH --time=24:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=%x-%j.log
#SBATCH --error=%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gres=gpu:1

# KinshipQA 2x2 Fictional-Substitution Ablation
# ----------------------------------------------
# Path Z: orthogonally decompose the +5.1pp gain observed in the
# full-fictional control (results_fictional_*) into:
#   (A) system-name substitution   -> datasets_fictional_system_only/
#   (B) kin-term substitution      -> datasets_fictional_term_only/
# Both real (datasets/) and full-fictional (datasets_fictional/) have
# already been evaluated, so we only run the two new partial conditions.

cd ~/scratch/Family-Tree-reasoning/familytree_v6/

module load Miniconda3
source activate MHQA

# Datasets are pre-built outside the job:
#   make_fictional_cat4.py --mode system_only --output-dir datasets_fictional_system_only/
#   make_fictional_cat4.py --mode term_only   --output-dir datasets_fictional_term_only/
# Re-run here defensively (idempotent, ~1 second).
python make_fictional_cat4.py \
    --input-dir ./datasets/ \
    --output-dir ./datasets_fictional_system_only/ \
    --mode system_only
python make_fictional_cat4.py \
    --input-dir ./datasets/ \
    --output-dir ./datasets_fictional_term_only/ \
    --mode term_only

OLLAMA_MODELS=~/scratch/ollama_model ~/scratch/bin/ollama serve &
OLLAMA_PID=$!
sleep 10

echo "========================================"
echo "KinshipQA 2x2 Fictional Ablation"
echo "Started: $(date)"
echo "========================================"

MODELS=("gemma3:27b" "deepseek-r1:32b" "qwen3:32b")
MODEL_NAMES=("gemma3_27b" "deepseek_r1_32b" "qwen3_32b")
CONDITIONS=("system_only" "term_only")

for COND in "${CONDITIONS[@]}"; do
    DATASET_DIR="./datasets_fictional_${COND}/"
    for i in "${!MODELS[@]}"; do
        MODEL="${MODELS[$i]}"
        MODEL_NAME="${MODEL_NAMES[$i]}"
        OUTPUT_DIR="./results_fictional_${COND}_${MODEL_NAME}_zero_shot_direct"

        echo ""
        echo "----------------------------------------"
        echo "Condition: ${COND} | Model: ${MODEL}"
        echo "Output:   ${OUTPUT_DIR}"
        echo "Time:     $(date)"
        echo "----------------------------------------"

        if [ -f "${OUTPUT_DIR}/combined_results.json" ]; then
            echo "Results already exist, skipping..."
            continue
        fi

        # Cat.4 only (the only category with substitution); kin systems
        # eskimo + sudanese carry only zero Cat.4 questions in datasets/,
        # but llm_tester_v6 will simply produce empty results for those.
        python llm_tester_v6.py \
            --all \
            --dataset-dir "$DATASET_DIR" \
            --provider ollama \
            --model "$MODEL" \
            --protocol zero_shot_direct \
            --categories 4 \
            --output-dir "$OUTPUT_DIR" \
            --verbose

        echo "Completed: ${COND} / ${MODEL} at $(date)"
    done
done

kill $OLLAMA_PID 2>/dev/null

echo ""
echo "========================================"
echo "Building 2x2 comparison table"
echo "========================================"

python aggregate_fictional_2x2.py \
    --output-json ./tables/fictional_2x2_summary.json \
    --output-tex  ./tables/fictional_2x2_table.tex

echo ""
echo "========================================"
echo "All evaluations complete: $(date)"
echo "========================================"
