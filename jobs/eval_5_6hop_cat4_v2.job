#!/usr/bin/env bash
#SBATCH --job-name=kinshipqa_56hop_cat4_v2
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=200G
#SBATCH --time=12:00:00
#SBATCH --account=cs-ontrel-2021
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=tianda.sun@york.ac.uk
#SBATCH --output=%x-%j.log
#SBATCH --error=%x-%j.err
#SBATCH --partition=gpuplus
#SBATCH --gres=gpu:1

# 5-6 Hop Cat.4 (cultural-override) evaluation — V2 with high max_tokens
# ---------------------------------------------------------------------
# V1 ran with default max_tokens=512 which caused DeepSeek-R1 (a reasoning
# model) and Qwen3 to truncate output before producing the final answer,
# resulting in 75-90% empty responses.  V2 uses max_tokens=8192 which is
# more than enough for the reasoning trace + answer.

cd ~/scratch/Family-Tree-reasoning/familytree_v6/

module load Miniconda3
source activate MHQA

DATA_DIR="./datasets_v6_3"

if [ ! -d "$DATA_DIR" ]; then
    echo "ERROR: $DATA_DIR does not exist."
    exit 1
fi

echo "========================================"
echo "5-6 hop Cat.4 evaluation V2 (max_tokens=8192)"
echo "Started: $(date)"
echo "Dataset:"
wc -l ${DATA_DIR}/*.jsonl
echo "========================================"

OLLAMA_MODELS=~/scratch/ollama_model ~/scratch/bin/ollama serve &
OLLAMA_PID=$!
sleep 10

MODELS=("gemma3:27b" "deepseek-r1:32b" "qwen3:32b")
MODEL_NAMES=("gemma3_27b" "deepseek_r1_32b" "qwen3_32b")

for i in "${!MODELS[@]}"; do
    MODEL="${MODELS[$i]}"
    MODEL_NAME="${MODEL_NAMES[$i]}"
    OUT="./results_5_6hop_cat4_${MODEL_NAME}_zero_shot_direct"

    if [ -f "${OUT}/combined_results.json" ]; then
        echo "Skipping ${MODEL}: results already exist"
        continue
    fi

    echo ""
    echo "--- ${MODEL} | 5 Other-5 systems x 5-6 hop Cat.4 (max_tokens=8192) ---"
    echo "Time: $(date)"

    python llm_tester_v6.py \
        --all \
        --dataset-dir "$DATA_DIR" \
        --provider ollama \
        --model "$MODEL" \
        --protocol zero_shot_direct \
        --categories 4 \
        --max-tokens 8192 \
        --output-dir "$OUT" \
        --verbose

    echo "Done ${MODEL}: $(date)"
done

kill $OLLAMA_PID 2>/dev/null
echo ""
echo "Finished: $(date)"
